ANTHROPIC_API_KEY=

# Langfuse (https://langfuse.com) — optional, enables LLM observability
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
# LANGFUSE_BASE_URL=https://cloud.langfuse.com  # default; change for self-hosted

# Supabase — optional, auto-creates tables and enables cloud persistence
# Get these from your Supabase project: Settings → API
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=   # Settings → API → service_role (keep secret, server-side only)
